{
  "name": "WRS",
  "private": true,
  "version": "3.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "webpack-dev-server --hot --allowed-hosts all",
    "build": "yarn make && yarn uglify && cp -r src/static dist && cp src/_redirects dist && cp prod/index.* dist && cp prod/config.js dist && cp -r prod/2018 dist && cp -r prod/2019 dist && cp -r prod/2020 dist && cp -r prod/2021 dist && cp -r prod/2022 dist && cp -r prod/2023 dist && cp -r prod/2024 dist && cp -r prod/2025 dist",
    "make": "elm make src/Main.elm --optimize --output dist/wrs.js",
    "uglify": "uglifyjs dist/wrs.js --compress 'pure_funcs=[F2,F3,F4,F5,F6,F7,F8,F9,A2,A3,A4,A5,A6,A7,A8,A9],pure_getters,keep_fargs=false,unsafe_comps,unsafe' | uglifyjs --mangle --output dist/wrs.js",
    "test": "yarn elm-test",
    "format": "yarn elm-format src"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "css-loader": "^7.1.4",
    "elm-analyse": "^0.16.5"
  },
  "devDependencies": {
    "elm": "^0.19.1-6",
    "elm-format": "^0.8.8",
    "elm-test": "^0.19.1-revision2",
    "elm-test-tests": "elm-explorations/test",
    "elm-webpack-loader": "^8.0.0",
    "style-loader": "^4.0.0",
    "uglify-js": "^3.19.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
